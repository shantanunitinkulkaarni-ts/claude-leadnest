# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key

# AI Brain — GLM primary, Cerebras fallback (see lib/llm.ts)
GLM_API_KEY=your_glm_api_key
CEREBRAS_API_KEY=your_cerebras_api_key

# WhatsApp — MSG91 (BSP) is primary; Meta Cloud API per-agent creds live in DB
MSG91_AUTHKEY=your_msg91_authkey
MSG91_WEBHOOK_SECRET=shared_secret_set_in_msg91_dashboard_header
WHATSAPP_VERIFY_TOKEN=leadnest_webhook_verify_2026
WHATSAPP_APP_SECRET=your_whatsapp_app_secret

# Email (Resend)
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=https://convorian.in

# Cron security (must match the GitHub Actions CRON_SECRET)
CRON_SECRET=any_random_secret_string

# Optional: an existing agent id used by local test harnesses
# TEST_AGENT_ID=
