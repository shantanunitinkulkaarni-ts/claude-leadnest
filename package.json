{
  "name": "leadnest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "playwright test -c playwright.unit.config.ts",
    "test:critical": "playwright test tests/critical --timeout=10000",
    "test:e2e": "playwright test tests/e2e --timeout=60000",
    "ci": "npm run lint && npm run typecheck && npm run test:unit && npm run test:critical && npm run test:e2e"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.56.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.7.2",
    "chrono-node": "^2.9.1",
    "date-fns": "^4.4.0",
    "next": "14.2.29",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
