{
  "name": "leadnest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:critical": "playwright test tests/critical --timeout=10000",
    "test:e2e": "playwright test tests/e2e --timeout=60000",
    "ci": "npm run lint && npm run typecheck && npm run test:critical && npm run test:e2e"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.56.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.7.2",
    "chrono-node": "^2.9.1",
    "date-fns": "^3.6.0",
    "next": "14.2.29",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "cross-env": "^10.1.0",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.1",
    "typescript": "^6"
  }
}
